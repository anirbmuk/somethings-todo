{
  "name": "somethings-todo",
  "version": "1.3.0",
  "private": true,
  "description": "A light and fast todo-app, built with Vue3 and Pinia",
  "author": {
    "name": "anirbmuk",
    "email": "anirbmuk@live.in",
    "url": "https://anirbmuk.appspot.com/en"
  },
  "repository": {
    "type": "github",
    "url": "https://github.com/anirbmuk/somethings-todo.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "cy:run": "cypress run --browser chrome",
    "cy:open": "cypress open --browser chrome",
    "cy:test": "cypress run --headless --browser chrome",
    "test": "TZ=UTC vitest",
    "test:ci": "TZ=UTC vitest --silent --watch=false",
    "test-e2e:ci": "start-server-and-test dev http://localhost:5173 cy:test",
    "format": "prettier . --write src/",
    "clean": "rimraf dist && rimraf .firebase && rimraf cypress/downloads",
    "prepare": "husky install",
    "host": "firebase deploy --only hosting",
    "deploy": "yarn clean && yarn build && yarn host"
  },
  "lint-staged": {
    "**/*.{js,ts,vue}": "eslint"
  },
  "dependencies": {
    "pinia": "^3.0.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^20.17.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/eslint-config-prettier": "^10.0.0",
    "@vue/eslint-config-typescript": "^14.1.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "@vueuse/core": "^13.0.0",
    "autoprefixer": "^10.4.20",
    "cypress": "^14.2.1",
    "eslint": "^9.13.0",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "eslint-plugin-vue": "^10.0.0",
    "firebase-tools": "^14.0.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.5.0",
    "npm-run-all2": "^7.0.1",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "radash": "^12.1.0",
    "rimraf": "^6.0.1",
    "start-server-and-test": "^2.0.11",
    "tailwindcss": "^3.4.14",
    "typescript": "~5.6.0",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.0.0",
    "vite-svg-loader": "^5.1.0",
    "vitest": "^3.0.9",
    "vue-tsc": "^2.2.8"
  },
  "resolutions": {
    "rollup": "4.24.0"
  }
}
