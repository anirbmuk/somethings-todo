{
  "name": "somethings-todo",
  "version": "1.9.9",
  "private": true,
  "description": "A light and fast todo-app, built with Vue3 and Pinia",
  "author": {
    "name": "anirbmuk",
    "email": "anirbmuk@live.in",
    "url": "https://anirbmuk.appspot.com/en"
  },
  "repository": {
    "type": "github",
    "url": "https://github.com/anirbmuk/somethings-todo.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "cy:run": "TZ=UTC cypress run --browser chrome",
    "cy:open": "TZ=UTC cypress open --browser chrome",
    "test": "TZ=UTC vitest",
    "test:ci": "TZ=UTC vitest --silent --watch=false",
    "test-e2e": "TZ=UTC cypress run --headless --browser chrome",
    "test-e2e:ci": "TZ=UTC start-server-and-test dev http://localhost:5173 test-e2e",
    "format": "prettier . --write src/",
    "clean": "rimraf dist && rimraf .firebase && rimraf cypress/downloads",
    "prepare": "husky",
    "host": "firebase deploy --only hosting",
    "deploy": "yarn clean && yarn build && yarn host"
  },
  "lint-staged": {
    "**/*.{js,ts,vue}": "eslint"
  },
  "dependencies": {
    "pinia": "^3.0.3",
    "vue": "^3.5.16",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.1",
    "@types/node": "^22.14.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "@vueuse/core": "^13.3.0",
    "autoprefixer": "^10.4.21",
    "cypress": "^14.2.1",
    "eslint": "^9.26.0",
    "eslint-plugin-sonarjs": "^3.0.2",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "eslint-plugin-vue": "^9.28.0",
    "firebase-tools": "^14.2.2",
    "husky": "^9.1.7",
    "js-base64": "^3.7.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.1",
    "npm-run-all2": "^8.0.1",
    "postcss": "^8.5.3",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "radash": "^12.1.0",
    "rimraf": "^6.0.1",
    "run-p": "^0.0.0",
    "start-server-and-test": "^2.0.11",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.0.0",
    "vite-svg-loader": "^5.1.0",
    "vitest": "^3.2.0",
    "vue-eslint-parser": "^10.0.0",
    "vue-tsc": "^2.2.10",
    "workbox-build": "^7.3.0",
    "workbox-window": "^7.3.0"
  },
  "resolutions": {
    "rollup": "^4.34.9"
  }
}
