{
  "name": "somethings-todo",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "A light and fast todo-app, built with Vue3 and Pinia",
  "author": {
    "name": "anirbmuk",
    "email": "anirbmuk@live.in",
    "url": "https://anirbmuk.appspot.com/en"
  },
  "repository": {
    "type": "github",
    "url": "https://github.com/anirbmuk/somethings-todo.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write src/",
    "clean": "rimraf dist",
    "prepare": "husky install",
    "host": "firebase deploy --only hosting",
    "deploy": "yarn clean && yarn build && yarn host"
  },
  "dependencies": {
    "pinia": "^3.0.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^20.17.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.0.0",
    "@vue/eslint-config-typescript": "^14.1.1",
    "@vue/tsconfig": "^0.5.1",
    "@vueuse/core": "^11.1.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "eslint-plugin-tailwindcss": "^3.17.5",
    "eslint-plugin-vue": "^9.29.0",
    "husky": "^8.0.3",
    "npm-run-all2": "^7.0.1",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "radash": "^12.1.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.14",
    "typescript": "~5.6.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^0.21.1",
    "vite-svg-loader": "^5.1.0",
    "vue-tsc": "^2.2.8"
  },
  "resolutions": {
    "rollup": "4.24.0"
  }
}
